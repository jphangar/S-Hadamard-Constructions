<Group labelreference="L104" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Function to group pairs of indices that are not equal to 1, a, or power of w</Text-field>
</Input>
</Group>
<Group labelreference="L105" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">groupPairs := proc(H::Matrix)
global EPS, ind, alf, n;
local cl, i, j;
  cl := {};
  for i to n^2 do
    if abs( eval( H[ ind[i,1], ind[i,2] ] - w , alf ) ) &gt; EPS
    and abs( eval( H[ ind[i,1], ind[i,2] ] - w^2 , alf ) ) &gt; EPS
    and abs( eval( H[ ind[i,1], ind[i,2] ] - 1 , alf) ) &gt; EPS
    and abs( eval( H[ ind[i,1], ind[i,2] ] - a, alf) ) &gt; EPS then
      for j from i+1 to n^2 do
        if abs( H[ ind[i,1], ind[i,2] ] - H[ ind[j,1], ind[j,2] ] ) &lt; EPS then
          cl := cl union { {ind[i], ind[j]} };
        fi;
      od;
    fi;
  od;
  cl;
end:</Text-field>
</Input>
</Group>
