<Group labelreference="L110" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Function to merge sets of indices</Text-field>
</Input>
</Group>
<Group labelreference="L111" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">groupPos := proc(pos::set)
local cl, ca, cb, loss;
  cl := {};
  loss := pos;
  for ca in pos do
    for cb in pos do
      if (nops(ca intersect cb) = nops(ca)-1) then
        cl := cl union {ca union cb};
        loss := loss minus {ca, cb};
      fi;
    od;
  od;
  return cl, loss;
end:</Text-field>
</Input>
</Group>
