<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Check if any entry in pts is a multiple by w of another in pts
multOfW := {}:
for pa in pts do
  mult := H[pa[1], pa[2]] / evalf(-1/2 + sqrt(3)*I/2);
  for pb in pts do
    if abs( mult - H[pb[1], pb[2]] ) &lt; EPS then
      multOfW := multOfW union { {pa, pb} };
    fi:
  od:
od:
multOfW;</Text-field>
</Input>
