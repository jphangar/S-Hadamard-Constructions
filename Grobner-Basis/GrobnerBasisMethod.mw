<Group labelreference="L437" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">updateMultiples := proc(idx::list, pos::set, par::algebraic)
global H, EPS, Hs;
local i, wpow, w2pow;
  wpow := H[idx[1], idx[2]]*evalf(-1/2 + sqrt(3)*I/2);
  w2pow := H[idx[1], idx[2]]*evalf(-1/2 + sqrt(3)*I/2)^2;
  for i from 1 to nops(pos) do
    if abs( wpow - H[pos[i][1][1], pos[i][1][2]] ) &lt; EPS then
      updatePos(Hs, pos[i], par*w);
    elif abs( w2pow - H[pos[i][1][1], pos[i][1][2]] ) &lt; EPS then
      updatePos(Hs, pos[i], par*w^2);
    fi;
  od;
end:</Text-field>
</Input>
</Group>
